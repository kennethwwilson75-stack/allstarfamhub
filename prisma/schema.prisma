generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── Core Identity ───────────────────────────────────────────────

model Family {
  id               String    @id @default(cuid())
  name             String
  timezone         String    @default("America/New_York")
  plan             Plan      @default(FREE)
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members      FamilyMember[]
  integrations Integration[]
  events       FamilyEvent[]
  alerts       Alert[]
  invites      FamilyInvite[]
  llmUsage     LlmUsage[]
  notificationPreferences NotificationPreferences[]
}

enum Plan {
  FREE
  PER_AGENT
  FAMILY
  DISTRICT
}

model FamilyMember {
  id          String     @id @default(cuid())
  familyId    String
  userId      String?
  role        MemberRole @default(CHILD)
  displayName String
  color       String     @default("#1D9E75")
  avatarUrl   String?
  grade       String?
  schoolName  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  events       EventMember[]
  integrations Integration[]

  @@index([familyId])
  @@index([userId])
}

enum MemberRole {
  ADMIN
  PARENT
  CHILD
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  supabaseId  String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pushTokens PushToken[]
  members    FamilyMember[]
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FamilyInvite {
  id        String    @id @default(cuid())
  familyId  String
  email     String
  role      MemberRole
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

// ─── Integrations ────────────────────────────────────────────────

model Integration {
  id              String            @id @default(cuid())
  familyId        String
  memberId        String?
  connectorId     String
  method          IntegrationMethod
  status          IntegrationStatus @default(PENDING)
  displayName     String

  // Credentials (encrypted at rest)
  credentialsEnc String?

  // OAuth tokens
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?

  // iCal / RSS feeds
  feedUrl String?

  // Email ingest
  ingestEmail String?

  // Scraper config
  scraperConfig Json?

  // Sync state
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?
  nextSyncAt     DateTime?
  syncIntervalMin Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family   Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member   FamilyMember? @relation(fields: [memberId], references: [id])
  rawItems RawItem[]

  @@index([familyId])
  @@index([connectorId])
  @@index([nextSyncAt])
}

enum IntegrationMethod {
  OAUTH_API
  ICAL_FEED
  EMAIL_PARSE
  WEB_SCRAPE
  MANUAL
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  PAUSED
  EXPIRED
}

// ─── Raw Ingestion Layer ──────────────────────────────────────────

model RawItem {
  id            String    @id @default(cuid())
  integrationId String
  sourceId      String
  rawPayload    Json
  parsedAt      DateTime?
  parseError    String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, sourceId])
  @@index([integrationId])
  @@index([processedAt])
}

// ─── Canonical Events ────────────────────────────────────────────

model FamilyEvent {
  id                  String  @id @default(cuid())
  familyId            String
  sourceIntegrationId String?
  sourceItemId        String?
  externalId          String?

  title       String
  description String?
  eventType   EventType

  startAt  DateTime
  endAt    DateTime?
  allDay   Boolean  @default(false)
  timezone String?

  location    String?
  locationUrl String?

  isRecurring   Boolean @default(false)
  recurringRule String?

  priority Priority    @default(NORMAL)
  status   EventStatus @default(ACTIVE)

  deadlineAt    DateTime?
  gradeWeight   Float?
  requiresSignup Boolean @default(false)
  signupUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  members   EventMember[]
  alerts    Alert[]
  changeLog EventChangeLog[]
  reminders EventReminder[]

  @@index([familyId])
  @@index([startAt])
  @@index([familyId, startAt])
  @@index([externalId, sourceIntegrationId])
}

enum EventType {
  ASSIGNMENT
  EXAM
  SCHOOL_EVENT
  NO_SCHOOL
  SPORTS
  MEETING
  ANNOUNCEMENT
  PERSONAL
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EventStatus {
  ACTIVE
  CANCELLED
  RESCHEDULED
  COMPLETED
}

model EventMember {
  eventId  String
  memberId String

  event  FamilyEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([eventId, memberId])
}

model EventChangeLog {
  id        String   @id @default(cuid())
  eventId   String
  field     String
  oldValue  String?
  newValue  String?
  changedAt DateTime @default(now())

  event FamilyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventReminder {
  id            String    @id @default(cuid())
  eventId       String
  userId        String
  minutesBefore Int
  sent          Boolean   @default(false)
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  event FamilyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([sent, sentAt])
}

// ─── Alerts & Notifications ───────────────────────────────────────

model Alert {
  id          String    @id @default(cuid())
  familyId    String
  eventId     String?
  type        AlertType
  title       String
  body        String
  priority    Priority  @default(NORMAL)
  readAt      DateTime?
  dismissedAt DateTime?
  actionUrl   String?
  createdAt   DateTime  @default(now())

  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  event  FamilyEvent? @relation(fields: [eventId], references: [id])

  @@index([familyId, createdAt])
  @@index([familyId, readAt])
}

enum AlertType {
  EVENT_ADDED
  EVENT_CHANGED
  EVENT_CANCELLED
  LOCATION_CHANGED
  TIME_CHANGED
  DEADLINE_TOMORROW
  DEADLINE_TODAY
  GRADE_POSTED
  SIGNUP_NEEDED
  SYNC_ERROR
  CONFLICT_DETECTED
}

// ─── Notification Preferences ─────────────────────────────────────

model NotificationPreferences {
  id        String  @id @default(cuid())
  familyId  String
  memberId  String?

  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)

  notifyEventAdded       Boolean @default(true)
  notifyEventChanged     Boolean @default(true)
  notifyLocationChanged  Boolean @default(true)
  notifyDeadlineToday    Boolean @default(true)
  notifyDeadlineTomorrow Boolean @default(true)
  notifyGradePosted      Boolean @default(false)
  notifyConflict         Boolean @default(true)

  quietHoursEnabled Boolean @default(true)
  quietHoursStart   String  @default("21:00")
  quietHoursEnd     String  @default("07:00")

  dailyDigestEnabled Boolean @default(false)
  dailyDigestTime    String  @default("07:00")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

// ─── Connector Registry ───────────────────────────────────────────

model ConnectorDefinition {
  id                String   @id
  displayName       String
  category          String
  logoUrl           String?
  description       String?
  methods           String[]
  oauthConfigJson   Json?
  icalInstructions  String?
  emailInstructions String?
  scraperAvailable  Boolean  @default(false)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── LLM Usage Tracking ──────────────────────────────────────────

model LlmUsage {
  id         String   @id @default(cuid())
  familyId   String
  date       String   // YYYY-MM-DD
  callCount  Int      @default(0)
  tokenCount Int      @default(0)
  costUsdMil Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, date])
  @@index([familyId])
}
