{
  "expo": {
    "name": "All Star Fam Hub",
    "slug": "allstarfamhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "allstarfamhub",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1D9E75",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.allstarfamhub.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D9E75"
      },
      "package": "com.allstarfamhub.app"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
