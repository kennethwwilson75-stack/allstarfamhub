# =============================================================================
# All Star Fam Hub — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.
# =============================================================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/allstarfamhub
DIRECT_URL=postgresql://postgres:localdev@localhost:5432/allstarfamhub

# --- Supabase ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Encryption ---
# 32-byte hex key: generate with `openssl rand -hex 32`
ENCRYPTION_MASTER_KEY=
CREDENTIAL_HMAC_SECRET=

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Anthropic (LLM parsing) ---
ANTHROPIC_API_KEY=

# --- SendGrid (email ingest) ---
SENDGRID_API_KEY=
SENDGRID_INBOUND_PARSE_API_KEY=

# --- OAuth / Connector Credentials ---
CANVAS_CLIENT_SECRET=
GOOGLE_CLIENT_SECRET=
SCHOOLOGY_CONSUMER_KEY=
SCHOOLOGY_CONSUMER_SECRET=

# --- Firebase (push notifications) ---
FIREBASE_PRIVATE_KEY=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Application URLs ---
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NODE_ENV=development

# --- Next.js Public (client-side) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_WS_URL=ws://localhost:3001
