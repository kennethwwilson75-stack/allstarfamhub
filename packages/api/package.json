{
  "name": "@allstarfamhub/api",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
