    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9"
  }
}
